@model CrudListViewModel

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item active">@Model.EntityName</li>
    </ol>
</nav>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="bi bi-table"></i> @Model.EntityName List</h5>
        <div class="d-flex gap-2">
            <input type="text" id="crud-search-box" class="form-control form-control-sm" placeholder="Search..." style="width:220px" />
            <a class="btn btn-primary btn-sm" asp-controller="Crud" asp-action="Create" asp-route-entity="@Model.EntityName">
                <i class="bi bi-plus-lg"></i> New @Model.EntityName
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="crud-table">
            <thead class="table-light">
                <tr>
                    @foreach (var prop in Model.Metadata.Properties)
                    {
                        <th>@prop.DisplayName</th>
                    }
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="@(Model.Metadata.Properties.Count + 1)" class="text-center text-muted py-4">
                            No @Model.EntityName records found.
                        </td>
                    </tr>
                }
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        @foreach (var prop in Model.Metadata.Properties)
                        {
                            var value = row.Values.GetValueOrDefault(prop.Name, "");
                            @if (prop.InputType == CrudInputType.Checkbox)
                            {
                                <td>
                                    @if (value == "Yes")
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>
                            }
                            else
                            {
                                <td>@value</td>
                            }
                        }
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="Crud" asp-action="Edit" asp-route-entity="@Model.EntityName" asp-route-id="@row.Id" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-danger" asp-controller="Crud" asp-action="Delete" asp-route-entity="@Model.EntityName" asp-route-id="@row.Id" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
