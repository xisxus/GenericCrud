@model CrudFormViewModel

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-entity="@Model.EntityName">@Model.EntityName</a></li>
        <li class="breadcrumb-item active">Delete</li>
    </ol>
</nav>

<div class="card shadow-sm border-danger" style="max-width:600px">
    <div class="card-header bg-danger text-white">
        <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete @Model.EntityName?</h5>
    </div>
    <div class="card-body">
        <p>Are you sure you want to delete this @Model.EntityName record? This cannot be undone.</p>

        <dl class="row">
            @foreach (var prop in Model.Metadata.Properties)
            {
                <dt class="col-sm-4">@prop.DisplayName</dt>
                <dd class="col-sm-8">@Model.Values.GetValueOrDefault(prop.Name)</dd>
            }
        </dl>

        <form method="post" asp-action="DeleteConfirmed" asp-route-entity="@Model.EntityName" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Yes, Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Index" asp-route-entity="@Model.EntityName">Cancel</a>
        </form>
    </div>
</div>
