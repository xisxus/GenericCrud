@model CrudFormViewModel

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-entity="@Model.EntityName">@Model.EntityName</a></li>
        <li class="breadcrumb-item active">@(Model.IsEdit ? "Edit" : "Create")</li>
    </ol>
</nav>

<div class="card shadow-sm" style="max-width:720px">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="bi @(Model.IsEdit ? "bi-pencil-square" : "bi-plus-circle")"></i>
            @(Model.IsEdit ? $"Edit {Model.EntityName}" : $"New {Model.EntityName}")
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Errors.Any())
        {
            <div class="alert alert-danger">
                <ul class="mb-0">
                    @foreach (var error in Model.Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        <form method="post"
              action="@(Model.IsEdit
                    ? Url.Action("Update", "Crud", new { entity = Model.EntityName, id = Model.Id })
                    : Url.Action("Save", "Crud", new { entity = Model.EntityName }))">
            @Html.AntiForgeryToken()

            @foreach (var prop in Model.Metadata.Properties.Where(p => !p.IsIdentity))
            {
                var value = Model.Values.GetValueOrDefault(prop.Name);

                @if (prop.IsPrimaryKey && Model.IsEdit)
                {
                    <input type="hidden" name="@prop.Name" value="@value" />
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label">
                            @prop.DisplayName
                            @if (prop.IsRequired)
                            {
                                <span class="text-danger">*</span>
                            }
                        </label>

                        @switch (prop.InputType)
                        {
                            case CrudInputType.Dropdown when prop.IsForeignKey:
                                <select name="@prop.Name" class="form-select" required="@prop.IsRequired">
                                    <option value="">-- Select @prop.DisplayName --</option>
                                    @foreach (var option in Model.DropdownOptions.GetValueOrDefault(prop.Name, new List<DropdownItem>()))
                                    {
                                        <option value="@option.Value" selected="@(option.Value == value)">@option.Text</option>
                                    }
                                </select>
                                break;

                            case CrudInputType.Dropdown:
                                <select name="@prop.Name" class="form-select" required="@prop.IsRequired">
                                    @foreach (var enumValue in Enum.GetNames(prop.UnderlyingType))
                                    {
                                        <option value="@enumValue" selected="@(enumValue == value)">@enumValue</option>
                                    }
                                </select>
                                break;

                            case CrudInputType.Checkbox:
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" name="@prop.Name" value="true" checked="@(value == "true")" />
                                </div>
                                break;

                            case CrudInputType.TextArea:
                                <textarea name="@prop.Name" class="form-control" rows="3"
                                          maxlength="@prop.MaxLength" required="@prop.IsRequired">@value</textarea>
                                break;

                            case CrudInputType.Number:
                                <input type="number" step="1" name="@prop.Name" class="form-control" value="@value"
                                       min="@prop.RangeMin" max="@prop.RangeMax" required="@prop.IsRequired" />
                                break;

                            case CrudInputType.Decimal:
                                <input type="number" step="0.01" name="@prop.Name" class="form-control" value="@value"
                                       min="@prop.RangeMin" max="@prop.RangeMax" required="@prop.IsRequired" />
                                break;

                            case CrudInputType.Date:
                                <input type="date" name="@prop.Name" class="form-control" value="@value" required="@prop.IsRequired" />
                                break;

                            case CrudInputType.Time:
                                <input type="time" name="@prop.Name" class="form-control" value="@value" required="@prop.IsRequired" />
                                break;

                            case CrudInputType.File:
                                <input type="file" name="@prop.Name" class="form-control" />
                                break;

                            default:
                                <input type="text" name="@prop.Name" class="form-control" value="@value"
                                       maxlength="@prop.MaxLength" required="@prop.IsRequired" />
                                break;
                        }
                    </div>
                }
            }

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                <a class="btn btn-outline-secondary" asp-action="Index" asp-route-entity="@Model.EntityName">Cancel</a>
            </div>
        </form>
    </div>
</div>
