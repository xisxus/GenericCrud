@model DynamicFormViewModel
@{
    var entity = ViewBag.EntityName as string;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-entity="@entity">@Model.Metadata.PageTitle</a></li>
        <li class="breadcrumb-item active">New</li>
    </ol>
</nav>

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-plus-lg"></i> New @Model.Metadata.PageTitle</h5>
    </div>
    <div class="card-body">
        <form method="post" enctype="multipart/form-data" asp-action="Create" asp-route-entity="@entity">
            @Html.AntiForgeryToken()
            @await Html.PartialAsync("_DynamicForm", Model)
            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
                <a class="btn btn-outline-secondary" asp-action="Index" asp-route-entity="@entity">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/dynamicCrud.js"></script>
}
