@model DynamicListViewModel
@{
    var entity = ViewBag.EntityName as string;
    var columns = Model.Metadata.TableFields;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/DynamicConfig">Dynamic Entities</a></li>
        <li class="breadcrumb-item active">@Model.Metadata.PageTitle</li>
    </ol>
</nav>

@Html.AntiForgeryToken()

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <h5 class="mb-0"><i class="bi bi-table"></i> @Model.Metadata.PageTitle</h5>
        <div class="d-flex gap-2">
            <form method="get" class="d-flex gap-2">
                <input type="hidden" name="sort" value="@Model.SortColumn" />
                <input type="hidden" name="dir" value="@Model.SortDirection" />
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm"
                       placeholder="Search..." style="width:220px" />
                <button type="submit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-search"></i></button>
            </form>
            <a class="btn btn-primary btn-sm" asp-action="Create" asp-route-entity="@entity">
                <i class="bi bi-plus-lg"></i> New
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    @foreach (var col in columns)
                    {
                        var nextDir = (Model.SortColumn == col.FieldName && Model.SortDirection?.ToLower() == "asc") ? "desc" : "asc";
                        <th>
                            <a class="text-decoration-none text-dark" href="?entity=@entity&search=@Model.Search&sort=@col.FieldName&dir=@nextDir">
                                @col.Label
                                @if (Model.SortColumn == col.FieldName)
                                {
                                    <i class="bi bi-caret-@(Model.SortDirection?.ToLower() == "asc" ? "up" : "down")-fill"></i>
                                }
                            </a>
                        </th>
                    }
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="@(columns.Count + 1)" class="text-center text-muted py-4">
                            No @Model.Metadata.PageTitle records found.
                        </td>
                    </tr>
                }
                @foreach (var row in Model.Rows)
                {
                    var id = row.GetValueOrDefault(Model.Metadata.PrimaryKeyColumn)?.ToString();
                    <tr>
                        @foreach (var col in columns)
                        {
                            <td>@Model.DisplayValue(row, col)</td>
                        }
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-entity="@entity" asp-route-id="@id" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger dyn-delete-btn"
                                    data-entity="@entity" data-id="@id" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <nav>
                <ul class="pagination pagination-sm mb-0 justify-content-end">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" href="?entity=@entity&search=@Model.Search&sort=@Model.SortColumn&dir=@Model.SortDirection&page=@p">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Delete confirm modal -->
<div class="modal fade" id="dynDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirm delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">Are you sure you want to delete this record?</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="dynDeleteConfirmBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dynamicCrud.js"></script>
}
