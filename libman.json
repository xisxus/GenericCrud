{
  "version": "3.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "jquery@3.7.1",
      "destination": "wwwroot/jquery/",
      "files": [
        "jquery.min.js"
      ]
    },
    {
      "library": "toastr.js@2.1.4",
      "destination": "wwwroot/toastr.js/",
      "files": [
        "toastr.min.js"
      ]
    },
    {
      "library": "fontawesome-iconpicker@3.2.0",
      "destination": "wwwroot/fontawesome-iconpicker/",
      "files": [
        "js/fontawesome-iconpicker.min.js"
      ]
    }
  ]
}